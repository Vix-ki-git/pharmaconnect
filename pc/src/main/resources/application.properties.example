# ===============================
# APP CONFIGURATION
# ===============================
# Copy this file to application.properties and fill in DB_PASSWORD locally,
# OR leave it untouched and let env vars / Codespaces secrets fill in values
# at runtime. Each ${VAR:default} reads env var VAR if set, else uses default.
spring.application.name=pharmaconnect
# Render sets PORT automatically; local/codespaces fall through to 10000.
server.port=${PORT:10000}

# ===============================
# DATABASE CONFIGURATION (MySQL)
# ===============================
# Local: set DB_PASSWORD to your MySQL root password (or edit it inline).
# Codespaces: DB_HOST is the docker-compose service name (e.g. "db");
#             DB_PASSWORD comes from the DB_PASSWORD Codespaces secret.
# Render / managed DB: set MYSQL_URL, MYSQL_USERNAME, MYSQL_PASSWORD.
# Local/Codespaces: leave those unset and DB_HOST/DB_USER/DB_PASSWORD apply.
spring.datasource.url=${MYSQL_URL:jdbc:mysql://${DB_HOST:localhost}:${DB_PORT:3306}/${DB_NAME:pharmaconnect}?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true}
spring.datasource.username=${MYSQL_USERNAME:${DB_USER:root}}
spring.datasource.password=${MYSQL_PASSWORD:${DB_PASSWORD:}}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ===============================
# JPA / HIBERNATE CONFIGURATION
# ===============================
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# ===============================
# CORS (used by global config in WebConfig)
# ===============================
# Comma-separated list. In Codespaces, set CORS_ORIGINS to the public 4200
# forwarded URL, e.g. https://your-codespace-4200.app.github.dev
app.cors.origins=${CORS_ORIGINS:http://localhost:4200,https://*.app.github.dev}

# ===============================
# THIRD-PARTY SERVICES
# ===============================
google.client.id=${GOOGLE_CLIENT_ID:}
google.client.secret=${GOOGLE_CLIENT_SECRET:}
brevo.api.key=${BREVO_API_KEY:DUMMY_VALUE}

# Groq — free tier. Get a key at https://console.groq.com/keys
groq.api.key=${GROQ_API_KEY:}
groq.model=${GROQ_MODEL:llama-3.3-70b-versatile}

# ===============================
# FILE UPLOADS
# ===============================
spring.servlet.multipart.max-file-size=5MB
spring.servlet.multipart.max-request-size=5MB
