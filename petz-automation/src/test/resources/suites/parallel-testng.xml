<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="PetzAutomationParallelSuite" verbose="1" parallel="methods" thread-count="3">

    <listeners>
        <listener class-name="com.cts.mfrp.petz.utils.ExtentReportListener"/>
    </listeners>

    <test name="PetzTestsParallel">
        <classes>
            <class name="com.cts.mfrp.petz.tests.LoginTest"/>
            <class name="com.cts.mfrp.petz.tests.EmployeeTest"/>
            <class name="com.cts.mfrp.petz.tests.LeaveTest"/>
        </classes>
    </test>

</suite>
